<configuration>

    <appender name="FILE.LOG" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/webapp.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/%d{yyyy_MM_dd}.webapp.log</fileNamePattern>
            <maxHistory>60</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%-50logger{50}] {%thread} %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="FILE.ERR" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/webapp.err</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/%d{yyyy_MM_dd}.webapp.err</fileNamePattern>
        </rollingPolicy>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%-50logger{50}] {%thread} %msg%n</pattern>
        </encoder>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
    </appender>

    <logger name="org.apache.commons" level="WARN" />
    <logger name="shipreq.webapp" level="DEBUG" />
    <logger name="com.googlecode.flyway" level="INFO" />
	<root level="INFO">
        <appender-ref ref="FILE.LOG" />
        <appender-ref ref="FILE.ERR" />
	</root>
</configuration>
