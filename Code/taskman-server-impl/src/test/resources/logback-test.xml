<configuration>

	<timestamp key="bySecond" datePattern="yyyyMMddHHmmss"/>

	<appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
		<encoder>
			<pattern>%-5level [%-40logger{40}] {%-40thread:%-9X{actor}} %msg%n</pattern>
		</encoder>
		<filter class="ch.qos.logback.classic.filter.ThresholdFilter">
			<level>INFO</level>
		</filter>
	</appender>

	<appender name="FILE.LOG" class="ch.qos.logback.core.FileAppender">
		<file>log/taskman-server-impl-test-${bySecond}.log</file>
		<encoder>
			<pattern>%d{HH:mm:ss.SSS} %-5level [%-50logger{50}] {%-40thread:%-9X{actor}} %msg%n</pattern>
		</encoder>
	</appender>

	<logger name="com.googlecode.flyway" level="INFO" />
	<logger name="scala.slick.compiler" level="WARN" />
    <logger name="scala.slick.session" level="INFO" />
    <logger name="com.jolbox.bonecp" level="DEBUG" />
    <logger name="shipreq" level="DEBUG" />

	<root level="DEBUG">
		<!--<appender-ref ref="STDOUT" />-->
		<appender-ref ref="FILE.LOG" />
	</root>
</configuration>
