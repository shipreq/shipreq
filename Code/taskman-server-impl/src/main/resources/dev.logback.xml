<configuration>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
		<encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
			<pattern>%d{HH:mm:ss.SSS} %-5level [%-32logger{32}] {%-10X{who}} %msg%n</pattern>
		</encoder>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>DEBUG</level>
        </filter>
	</appender>

    <appender name="FILE.LOG" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/taskman-dev.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/taskman-dev-%d{yyyyMMdd}.log</fileNamePattern>
            <maxHistory>60</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%-44logger{44}] {%-15thread:%-10X{who}} %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="com.googlecode.flyway" level="INFO" />
    <logger name="com.jolbox.bonecp" level="INFO" />

    <logger name="akka" level="DEBUG" />
    <logger name="akka.event.slf4j" level="WARN" />
    <logger name="akka.event.EventStream" level="WARN" />

    <logger name="shipreq" level="DEBUG" />

    <root>
        <appender-ref ref="STDOUT" />
        <appender-ref ref="FILE.LOG" />
	</root>
</configuration>
