taskman.mail.support.to      = japgolly+support_to@gmail.com
taskman.mail.concurrency.max = 4

taskman.work.queueSize      = 10
taskman.work.trustPeriod    = 3 min
taskman.work.poll.every     = 5 sec
taskman.work.poll.min       = 1 sec
