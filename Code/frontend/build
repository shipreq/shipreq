#!/bin/bash

# Run via docker if not already
if [ -z "$SHIPREQ_DEV_NODE" ]; then
  exec docker run \
    --rm \
    --user $(id -u):$(id -g) \
    -v "$(pwd)":/host:rw \
    shipreq/dev/node \
    /host/"$(basename "$0")" \
    "$@"
fi

# ====================================================================================================================
cd "$(dirname "$(readlink -e "$0")")" || exit 1

args="$@"
[ $# -eq 0 ] && args=(dev prod local)

webpack="node_modules/.bin/webpack --progress --config"
webtamp="node_modules/.bin/webtamp"
[ -n "$WEBTAMP" ] && webtamp="$WEBTAMP/src/cli.js"
webtamp="$webtamp --config"

for mode in ${args[@]}; do
  echo "--------------------------------------------------------------------------------"
  echo "[$mode]"
  case "$mode" in

    dev|prod)

      # Clean
      target1=/tmp/shipreq.webpack.$mode
      target2=dist/$mode
      rm -rf $target1 $target2

      # Webpack
      $webpack webpack/$mode.js || exit $?
      rm -f $target1/{admin}.js # These are empty. Their entrypoints in webpack exist for CSS only.
      dos2unix $target1/*.{css,js}
      [ $mode == prod ] && perl -pi -e 's/\n//g' $target1/*.css
      echo

      # Webtamp
      $webtamp webtamp/$mode.js || exit $?

      # Done
      echo
      du -sh $target2/serve
      ;;

    local)
      target=dist/local
      rm -rf $target
      $webpack webpack/local.js || exit $?
      echo
      ls -l $target
      ;;

    *) echo What?
  esac
  echo
done
