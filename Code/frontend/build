#!/bin/bash

cd "$(dirname "$(readlink -e "$0")")" || exit 1

# Run via docker if not already
if [ -z "$SHIPREQ_DEV_NODE" ]; then
  exec ./exec ./"$(basename "$0")" "$@"
fi

# ====================================================================================================================

valid_targets=(dev prod test test-node ssr)

args="$@"
[ $# -eq 0 ] && args="${valid_targets[@]}"

webpack="node_modules/.bin/webpack --color --display-reasons --display-modules --progress --config"
webtamp="node_modules/.bin/webtamp"
[ -n "$WEBTAMP" ] && webtamp="$WEBTAMP/dist/cli.js"
webtamp="$webtamp --config"

for mode in ${args[@]}; do
  echo "--------------------------------------------------------------------------------"
  echo "[$mode]"
  case "$mode" in

    dev|prod)

      # Clean
      target1=/tmp/shipreq.webpack.$mode
      target2=dist/$mode
      rm -rf $target1 $target2 analysis/$mode.*

      # Webpack
      $webpack webpack/$mode.js || exit $?
      rm -f $target1/{admin}.js # These are empty. Their entrypoints in webpack exist for CSS only.
      dos2unix $target1/*.{css,js}
      [ $mode == prod ] && perl -pi -e 's/\n//g' $target1/*.css
      cp $target1/analysis/* analysis/.
      echo

      # Webtamp
      $webtamp webtamp/$mode.js || exit $?

      # Analysis
      stats=analysis/$mode.json
      report=analysis/$mode.txt
      ./node_modules/.bin/webpack-bundle-size-analyzer < $stats \
        | fgrep -v 'calculated before minification' \
        | perl -pe 's/: /,/; s/ \(/,/; s/%\)$//' | column -t -s, | sort -k4nr | perl -pe 's/$/%/' \
        > $report
      echo
      cat $report

      # Done
      echo
      du -sh $target2/serve
      ;;

    test)
      target=dist/test
      rm -rf $target
      $webpack webpack/test.js || exit $?
      echo
      ls -l $target
      ;;

    test-node)
      target=dist/test-node
      rm -rf $target
      $webpack webpack/test-node.js || exit $?
      echo
      ls -l $target
      ;;

    ssr)
      target=dist/ssr
      rm -rf $target
      $webpack webpack/ssr.js || exit $?
      echo
      ls -l $target
      ;;

    *)
      echo What?
      echo "Valid targets are: ${valid_targets[@]}"
  esac
  echo
done
