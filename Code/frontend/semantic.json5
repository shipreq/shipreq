{
  "base": "semantic/",
  "paths": {
    "source": {
      "config": "src/theme.config",
      "definitions": "src/definitions/",
      "site": "src/site/",
      "themes": "src/themes/"
    },
    "output": {
      "packaged": "dist/",
      "uncompressed": "dist/components/",
      "compressed": "dist/components/",
      "themes": "dist/themes/"
    },
    "clean": "dist/"
  },
  "permission": false,
  "rtl": "No",

  // Not sure if the order matters here but will leave it in its original order just in case.
  "components": [
    "reset",       // Ensures consistent underlying styles across browsers.
    "site",        // Ensures consistent underlying styles across browsers.
    "button",      // Used all over the place.
    "container",   // Used in members-project-access_revoked.html
    //"divider",
    //"flag",
    "header",      // Used in (loaded) project menu (/project/ABC).
    "icon",        // Used all over the place.
    //"image",
    "input",       // Used all over the place.
    "label",       // Used to display error messages of <input>/<textarea>
    //"list",
    "loader",      // Used when loading project (/project/ABC).
    //"rail",
    //"reveal",
    "segment",     // Used when loading project (/project/ABC).
    //"step",
    "breadcrumb",  // Used in top-left of in all logged-in pages
    "form",        // Used in public pages (eg. login, register), user profile page
    //"grid",
    "menu",        // Used at top of all logged-in pages
    "message",     // Used when project fails to load (/project/ABC).
    "table",       // Used for rich-text editor help, and filter help.
    //"ad",
    "card",        // Used in (loaded) project menu (/project/ABC).
    //"comment",
    //"feed",
    //"item",
    "statistic",   // Used in projects index (/), and each project's home (/project/ABC)
    //"accordion",
    "checkbox",    // Used in public pages (eg. login, register), user profile page
    "dimmer",      // Used in [Req Lookup] card in project menu (/project/ABC).
    "dropdown",    // Used in top-right of all logged-in pages
    //"embed",
    "modal",       // Used for rich-text editor help, and filter help.
    //"nag",
    "popup",       // Used in FilterDead buttons
    //"progress",
    //"rating",
    "search",      // Used in ProjectIndex → ReqDetail card → search prompt
    //"shape",
    //"sidebar",
    //"sticky",
    //"tab",
    "transition",  // Required by dropdown, also used to flash errors in PublicSpa
    //"api",
    //"form",
    //"state",
    //"visibility",
  ],
  "version": "2.2.13"
}
