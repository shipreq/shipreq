{
    "base": "semantic/",
    "paths": {
        "source": {
            "config": "src/theme.config",
            "definitions": "src/definitions/",
            "site": "src/site/",
            "themes": "src/themes/"
        },
        "output": {
            "packaged": "dist/",
            "uncompressed": "dist/components/",
            "compressed": "dist/components/",
            "themes": "dist/themes/"
        },
        "clean": "dist/"
    },
    "permission": false,
    "rtl": "No",
    "components": [
        "reset",
        "site",
        "button",
        "header",
        "icon",
        "input",
        "label",
        "loader",
        "segment",
        "breadcrumb",
        "form",
        "menu",
        "message",
        "table",
        "card",
        "statistic",
        "checkbox",
        "dimmer",
        "dropdown",
        "modal",
        "popup",
        "search",
        "transition"
    ],
    "version": "2.2.13"
}