{
  "base": "semantic/",
  "paths": {
    "source": {
      "config": "src/theme.config",
      "definitions": "src/definitions/",
      "site": "src/site/",
      "themes": "src/themes/"
    },
    "output": {
      "packaged": "dist/",
      "uncompressed": "dist/components/",
      "compressed": "dist/components/",
      "themes": "dist/themes/"
    },
    "clean": "dist/"
  },
  "permission": false,
  "rtl": "No",

  // Not sure if the order matters here but will leave it in its original order just in case.
  "components": [
    "reset",       // Ensures consistent underlying styles across browsers.
    "site",        // Ensures consistent underlying styles across browsers.
    "button",      // Used all over the place.
    //"container",
    //"divider",
    //"flag",
    //"header",
    "icon",        // Used all over the place.
    //"image",
    "input",       // Used all over the place.
    "label",       // Used to display error messages of <input>/<textarea>
    //"list",
    //"loader",
    //"rail",
    //"reveal",
    //"segment",
    //"step",
    "breadcrumb",  // Used in top-left of in all logged-in pages
    //"form",
    //"grid",
    "menu",        // Used at top of all logged-in pages
    //"message",
    //"table",
    //"ad",
    //"card",
    //"comment",
    //"feed",
    //"item",
    "statistic",   // Used in projects index (/), and each project's home (/project/ABC)
    //"accordion",
    //"checkbox",
    //"dimmer",
    "dropdown",    // Used in top-right of all logged-in pages
    //"embed",
    //"modal",
    //"nag",
    //"popup",
    //"progress",
    //"rating",
    //"search",
    //"shape",
    //"sidebar",
    //"sticky",
    //"tab",
    //"transition",
    //"api",
    //"form",
    //"state",
    //"visibility",
  ],
  "version": "2.1.8"
}
