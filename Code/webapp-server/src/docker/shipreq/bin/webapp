#!/bin/bash

set -euo pipefail

####################################################################################################

function onExit() {
  # Note: echos are in a sub-shell because STDOUT is likely already closed
  exitStatus="$1"
  lineNo="$2"
  (echo "Exiting with status $exitStatus from line $lineNo")
  exit $exitStatus
}

function onSig() {
  # Note: echos are in a sub-shell because STDOUT is likely already closed
  exitStatus="$1"
  name="$2"
  (echo "Recieved SIG$name")
  exit $exitStatus
}

trap "onSig 129 HUP" HUP
trap "onSig 130 INT" INT
trap "onSig 137 KILL" KILL
trap "onSig 139 SEGV" SEGV
trap "onSig 143 TERM" TERM
trap "onSig 152 XCPU" XCPU
trap "onSig 153 XFSZ" XFSZ

trap 'onExit $? $LINENO' EXIT

####################################################################################################

cmd=("$JETTY_BASE/bin/jetty")

i="$(printenv run.mode)"
[ -n "$i" ] && cmd+=("-Drun.mode=$i")
[ -n "${RUN_MODE:-}" ] && cmd+=("-Drun.mode=$RUN_MODE")

cmd+=("$@")

# This is a little util in shipreq/base that imports files from an external
# source depending on config. For example, SSL passwords.
import-files

mkdir -p resources
if [ ! -e resources/logback.xml ]; then
  cp webapps/ROOT/WEB-INF/classes/logback.xml resources/logback.xml
fi

# Replace static links in webpack output :(
i="$(printenv shipreq.staticAssetCdn || true)"
echo "shipreq.staticAssetCdn = [$i]"
if [ -n "$i" ]; then
  src=/shipreq/webapps/ROOT
  orig=/shipreq/original-res

  for dir in s templates-hidden; do
    mkdir -p $orig/$dir
  done

  for f in $(find $src -name '*.html' -o -path '*/s/*.xml' | sed "s,$src/,,"); do
    echo "Redirecting static assets to $i in $f"
    [ ! -e $orig/$f ] && cp $src/$f $orig/$f
    sed "s,=\"/s/,=\"$i/,g" <$orig/$f >$src/$f
    rm -f $src/$f.{br,gz}
  done

  for f in $(find $src -path '*/s/*.webmanifest' | sed "s,$src/,,"); do
    echo "Redirecting static assets to $i in $f"
    [ ! -e $orig/$f ] && cp $src/$f $orig/$f
    sed "s,\" *: *\"/s/,\": \"$i/,g" <$orig/$f >$src/$f
    rm -f $src/$f.{br,gz}
    gzip -9 <$src/$f >$src/$f.gz
  done
fi

####################################################################################################

"${cmd[@]}" --list-config | grep -iv password || true

"${cmd[@]}"