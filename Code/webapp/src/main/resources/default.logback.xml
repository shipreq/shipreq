<configuration>
    <timestamp key="byDay" datePattern="yyyyMMdd"/>

	<appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
		<encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
			<pattern>%d{HH:mm:ss.SSS} %-5level [%-32logger{32}] %msg%n</pattern>
		</encoder>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>INFO</level>
        </filter>
	</appender>

    <appender name="FILE.LOG" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>log/webapp-dev.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>log/webapp-dev-%d{yyyyMMdd}.log</fileNamePattern>
            <maxHistory>60</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%-50logger{50}] {%thread} %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="FILE.ERR" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>log/webapp-dev.err</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>log/webapp-dev-%d{yyyyMMdd}.err</fileNamePattern>
        </rollingPolicy>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%-50logger{50}] {%thread} %msg%n</pattern>
        </encoder>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
    </appender>

    <logger name="org.apache.commons" level="WARN" />
    <logger name="scala.slick.compiler" level="WARN" />
    <logger name="scala.slick.jdbc" level="DEBUG" />
    <logger name="shipreq.webapp" level="DEBUG" />
    <!--logger name="com.googlecode.flyway" level="INFO" /-->
	<root level="DEBUG">
        <appender-ref ref="STDOUT" />
        <appender-ref ref="FILE.LOG" />
        <appender-ref ref="FILE.ERR" />
	</root>
</configuration>
