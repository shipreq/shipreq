<configuration>
    <timestamp key="byDay" datePattern="yyyyMMdd"/>

    <appender name="FILE.LOG" class="ch.qos.logback.core.FileAppender">
        <file>log/shipreq-${byDay}.log</file>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%-50logger{50}] {%thread} %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="FILE.ERR" class="ch.qos.logback.core.FileAppender">
        <file>log/shipreq-${byDay}.err</file>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%-40logger{40}] %msg%n</pattern>
        </encoder>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
    </appender>

    <logger name="org.apache.commons" level="WARN" />
    <logger name="scala.slick.compiler" level="WARN" />
    <logger name="scala.slick.jdbc" level="DEBUG" />
    <logger name="shipreq.webapp" level="DEBUG" />
    <logger name="com.googlecode.flyway" level="INFO" />
	<root level="INFO">
        <appender-ref ref="FILE.LOG" />
        <appender-ref ref="FILE.ERR" />
	</root>
</configuration>
