#!/bin/bash

cd "$(dirname "$(readlink -e "$0")")" || exit 1
bin=$(pwd)

f=../Experimentation/scalajs/src/main/scala/shipreq/webapp/client/ui/table/SpecN.scala
f=webapp-client/src/main/scala/shipreq/webapp/client/util/ui/table/SpecN.scala
cd "../$(dirname "$f")" || exit 1
f="$(basename "$f")"

[ -e "$f" ] && mv -v "$f" /tmp
echo Generating...
"$bin/gen-tablespec" > "$f" && ls -l "$f"

