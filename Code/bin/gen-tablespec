#!/bin/env scala

// vim: set ft=scala :

val comma = ","
def T(i: Int) = (64+i).toChar.toString

var B = List.empty[String]

print("""package shipreq.webapp.client.ui.table

import japgolly.scalajs.react.ComponentStateFocus
import scalaz.effect.IO
import scalaz.{Bind, Equal}
import scalaz.syntax.bind._
import shipreq.base.util.ScalaExt._
import shipreq.webapp.client.ui.Implicits._
import shipreq.webapp.client.ui._
import shipreq.webapp.shared.validation.{ValidatePlusR, ValidatorPlus}

object SpecN {""")

for (a <- (1 to 9)) {
// println(s"// Arity: $a")

  def m (f: Int ⇒ String): List[String] = (1 to a).toList.map(f)
  def mc(f: Int ⇒ String): String = m(f).mkString(comma)
  def mt(f: Int ⇒ String): String = if (a==1) f(1) else m(f).mkString("(",comma,")")
  def mn(f: Int ⇒ String): String = m(f).mkString("\n")
  def mb(f: Int ⇒ String): String = m(f).mkString(",\n")
  // def TO(i: Int)  = T(i) + "O"
  // def TTO(i: Int) = T(i) + "," + TO(i)
  // def VD(i: Int)  = s"FormVar[${TTO(i)}]"
  // def v(i: Int)   = T(i).toLowerCase
  // def vVD(i: Int) = s"${v(i)}: ${VD(i)}"
  def IeCOn(i: Int) = s"I$i: Equal,C$i,O$i"
  def ICOn(i: Int) = s"I$i,C$i,O$i"

  def IeCO  = mc(IeCOn)
  def ICO   = mc(ICOn)
  def spec  = mc(i ⇒ s"s$i: FieldSpec[P,V,I$i,C$i,O$i]")
  def specR = mc(i ⇒ s"s$i: FieldSpecR[S,R,P,V,I$i,C$i,O$i]")
  def II    = mt(i ⇒ s"I$i")
  def OO    = mt(i ⇒ s"O$i")
  def os    = mt(i ⇒ s"o$i")
  def VV    = mt(_ ⇒ "V")
  def vs    = mt(i ⇒ s"v$i")
  def ss    = mc(i ⇒ s"s$i")
  def cvs   = mc(i ⇒ s"cv$i: Option[ValidatePlusR[S,R,O$i]]")

  def ta(i: Int) = if (a==1) "" else s"._$i" //tuple access
  def iLmap(i: Int) = if (a==1) "" else s".mapF(_${ta(i)})((a,b) ⇒ a put$i b)"
  def tupled = if (a==1) "" else ".tupled"

  def in = mt(i ⇒ s"s$i initial p")
  def vn = mn(i ⇒ s"      val v$i = s$i.vr.fold[S ⇒ ValidatorPlus[${ICOn(i)}]](_⇒ s$i.v)(s$i.v stateful _(w))")
  def sn = mn(i ⇒ s"        o$i ← v$i(s).correctAndValidate(e${ta(i)}).toOption")
  def en = mb(i ⇒ s"        new SmartEditor[S,${ICOn(i)},M](v$i, s2mp.andThen(_ map s$i.p2c), iL${iLmap(i)}, sf)").replaceFirst("^ +","")
  def rn = mn(i ⇒ s"            v$i ← s${ta(i)}.render(s$i.e, T)")

  def RS = s"RowSpec$a"
  def SB = s"TableSpecBuider$a"

  B = s"  def apply[V, $IeCO]($spec) = new $SB[P,$OO,V,$ICO]($ss,x⇒x)" :: B

  print(s"""

  final case class $RS[S, R, U, P, V, $IeCO]($specR, buildU: ($OO) ⇒ U) extends RowSpec[S, R, U, P, $II, $VV] {
    override def initial(p: P): $II = $in
    private def fieldRenderers[M[_] : Bind : Optional2](s2mp: S ⇒ M[P], w: R, save: (S, U) ⇒ IO[S], iL: WeirdLens[M,S,S,$II]) = {
$vn
      def savable(s: S, e: $II): Option[$OO] = for {
$sn
      } yield $os
      // TODO This isn't able to traverse other rows, or access them by R
      // Cannot save rows that were invalid due to this one, that have just become valid.
      val sf: S ⇒ IO[S] = s ⇒ iL.get(s).toOption.flatMap(savable(s, _)).fold(IO(s))(oo ⇒ save(s, buildU(oo)))
      ( $en)
    }
    override def forRow(w: R): RowRenderer[S, U, P, $II, $VV] =
      new RowRenderer[S, U, P, $II, $VV] {
        override def renderM[M[_] : Bind : Optional2](iL: WeirdLens[M,S,S,$II], s2mp: S ⇒ M[P])(save: (S,U) ⇒ IO[S]): ComponentStateFocus[S] ⇒ M[$VV] = T ⇒ {
          val s = fieldRenderers(s2mp, w, save, iL)
          for {
$rn
          } yield $vs
        }
      }
  }

  final class $SB[P, U, V, $IeCO]($spec, buildU: ($OO) ⇒ U) {
    def mapU[UU](f: U ⇒ UU) = new $SB($ss, f compose buildU)
    def buildU[UU](f: $OO ⇒ UU) = new $SB($ss, f$tupled)
    def dataId[D] = new B2[D]
    final class B2[D] {
      type R = Option[D]
      type S = SavedAndUnsaved[D, P, $II]
      def uniquenessCheck[A: Equal](f: P ⇒ A) =
        TableConstraint.uniquenessT[D,P,$II,A](f)
      def tableConstraints($cvs) =
        TableSpecB default $RS(${mc(i => s"s$i toR cv$i")},buildU)
    }
  }""")
}
print(s"""
}

import SpecN._
final class TableSpecBuilder[P] {
${B.reverse.mkString("\n")}
}
object TableSpecBuilder { def apply[P] = new TableSpecBuilder[P] }
""")
