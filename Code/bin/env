#!/bin/bash

cd "$(dirname "$(readlink -e "$0")")/../docker" || exit 1

if [ $# -eq 0 ]; then
  self="$0"
  echo "Usage:"
  echo "  $self <env> [docker-compose-args...]"
  echo "Examples:"
  echo "  $self test up -d"
  echo "  $self dev up"
  exit 1
fi

env="$1"
shift

dc="$env/docker-compose.yml"
[ ! -e "$dc" ] && echo "File not found: $(pwd)/$dc" && exit 2

# In project name (-p) dashes and underscores and removed automatically
exec docker-compose \
  -f "$dc" \
  -p shipreq$env \
  "$@"
