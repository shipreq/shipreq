#!/bin/bash
cd "$(dirname "$0")/.." || exit 1
[ $# -ne 0 ] && echo "Usage: $0" && exit 1

target="${SHIPREQ_RELEASE_TARGET:-.}"
jsPublic="$target/webapp-client-public/js/target/scala-2.13/webapp-client-public-opt.js"
jsHome="$target/webapp-client-home/target/scala-2.13/webapp-client-home-opt.js"
jsProject="$target/webapp-client-project/target/scala-2.13/webapp-client-project-opt.js"

# Run SBT if necessary
updateCmd="sbt -DMODE=release -DemitSourceMaps=1 webapp-server/webappPostProcess"
echo "Update command: $updateCmd"
if [ -e "$jsProject" ]; then
  echo "  Skipping..."
else
  echo "  Generating..."
  $updateCmd
fi
echo

function go {
  js="$1"
  name="$2"
  base="analysis/$name"
  echo "Generating $base.* ..."
  bin/source-map-explorer "$js" --html "$base.html"
  bin/source-map-explorer "$js" --json "$base.json"
  bin/source-map-explorer "$js" --tsv  "$base.tsv"
  echo
}

go "$jsPublic"  spa-public
go "$jsHome"    spa-home
go "$jsProject" spa-project

echo "Done."