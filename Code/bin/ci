#!/bin/bash

###########################################
# Note: To test this locally...           #
#   1. make build_env                     #
#   2. bin/ci                             #
###########################################

unset JAVA_OPTS
unset JVM_OPTS
unset SBT_OPTS
unset SBTX_OPTS

arg1="$1"

set -uo pipefail

cd "$(dirname "$0")"/..
aws="bin/aws"

sbt=()

[ -n "${DRY_RUN:-}" ] && sbt+=(echo)

dump=/tmp/ci-oom-$(date +%Y%m%d-%H%M%S).dump

sbt+=(
  sbt
  -DCI=1
  -DMODE=release
  -Dsbt.server.autostart=false
  -Dsbt.server.forcestart=true # https://github.com/sbt/sbt/issues/6101
  -Dsbt.supershell=never
  -J-XX:+ExitOnOutOfMemoryError
  -J-XX:+HeapDumpOnOutOfMemoryError
  -J-XX:HeapDumpPath=$dump
)

if [ -z "${LOCAL_CI:-}" ]; then
  sbt+=(
    -J-Xmx8g
    -no-colors
  )
else
  # Need to re-login to ECR from local CI env
  $($aws ecr get-login --no-include-email)
fi

function run {
  echo
  if [ -n "${LOCAL_CI:-}" ]; then
    echo "> ${sbt[@]} $@"
    "${sbt[@]}" "$@"
  else
    echo "> ${sbt[@]} $@ | strip-ansi"
    "${sbt[@]}" "$@" | strip-ansi
  fi
  r=$?
  echo "Exit status = $r"
  if [ -e $dump ]; then
    echo "Java OOM detected! filename = $(basename $dump)"
    ls -l $dump
    gzip -9 <$dump >$dump.gz
    $aws s3 cp $dump.gz s3://shipreq-tmp/
  fi
  return $r
}

docker_args=(taskmanServer/docker webappServer/docker)
[ "${DOCKER_PUSH:-}" != 0 ] && docker_args+=(taskmanServer/dockerPush webappServer/dockerPush)

TMP_TARGET="$(ls -l | fgrep 'target -> ' | sed 's/^.* //')"
[ -n "$TMP_TARGET" ] && mkdir -p "$TMP_TARGET"

if [ "$arg1" = shell ]; then
  echo "> ${sbt[@]}"
  exec "${sbt[@]}"
fi

echo "Ensuring S3 access..." \
  && $aws s3 ls s3://shipreq-tmp/ \
  && run test:compile \
  && run test \
  && run "${docker_args[@]}"
