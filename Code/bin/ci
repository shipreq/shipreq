#!/bin/bash

###########################################
# Note: To test this locally...           #
#   1. make build_env                     #
#   2. bin/ci                             #
###########################################

unset JAVA_OPTS
unset JVM_OPTS
unset SBT_OPTS
unset SBTX_OPTS

set -uo pipefail

cd "$(dirname "$0")"/..

sbt=()

[ -n "${DRY_RUN:-}" ] && sbt+=(echo)

dump=/tmp/ci-oom-$(date +%Y%m%d-%H%M%S).dump

sbt+=(
  sbt
  -DCI=1
  -DMODE=release
  -Dsbt.server.autostart=false
  -J-XX:+ExitOnOutOfMemoryError
  -J-XX:+HeapDumpOnOutOfMemoryError
  -J-XX:HeapDumpPath=$dump
)

[ -z "${LOCAL_CI:-}" ] && sbt+=(
  -J-Xmx8g
  -no-colors
)

function run {
  echo
  if [ -n "${LOCAL_CI:-}" ]; then
    echo "> ${sbt[@]} $@"
    "${sbt[@]}" "$@"
  else
    echo "> ${sbt[@]} $@ | strip-ansi"
    "${sbt[@]}" "$@" | strip-ansi
  fi
  r=$?
  echo "Exit status = $r"
  if [ -e $dump ]; then
    echo "Java OOM detected! filename = $(basename $dump)"
    ls -l $dump
    gzip -9 <$dump >$dump.gz
    aws s3 cp $dump.gz s3://shipreq-tmp/
  fi
  return $r
}

docker_args=(taskmanServer/docker webappServer/docker)
[ "${DOCKER_PUSH:-}" != 0 ] && docker_args+=(taskmanServer/dockerPush webappServer/dockerPush)

echo "Ensuring S3 access..." \
  && aws s3 ls s3://shipreq-tmp/ \
  && run test:compile \
  && run test \
  && run "${docker_args[@]}"
