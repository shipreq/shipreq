#!/bin/bash

set -euo pipefail

cd "$(dirname "$0")"

$(./aws ecr get-login --profile=shipreq --region=ap-southeast-2 --no-include-email) || exit 1

for app in webapp taskman; do
  echo

  l=shipreq/$app:latest
  r=930801536115.dkr.ecr.ap-southeast-2.amazonaws.com/shipreq/$app:latest

  docker tag $l $r && docker push $r

done
