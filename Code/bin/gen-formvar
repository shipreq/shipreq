#!/bin/env scala

// vim: set ft=scala :

val comma = ", "
def T(i: Int) = (64+i).toChar.toString

for (a <- (2 to 9)) {
// println(s"// Arity: $a")

  def m (f: Int => String): List[String] = (1 to a).toList.map(f)
  def mc(f: Int => String): String = m(f).mkString(comma)
  def mt(f: Int => String): String = m(f).mkString("(",comma,")")
  def TO(i: Int)  = T(i) + "O"
  def TTO(i: Int) = T(i) + "," + TO(i)
  def VD(i: Int)  = s"FormVar[${TTO(i)}]"
  def v(i: Int)   = T(i).toLowerCase
  def vVD(i: Int) = s"${v(i)}: ${VD(i)}"

  if (false) print(s"""
  final case class V$a[${mc(TTO)}]${mt(vVD)} {
    type Vars = ${mt(T)}
    def init = ${mt(v(_)+".init")}
    def cssSel(get: => Vars, set: Vars => Unit): CssSel = ${m(j => s"${v(j)}.csssel(get._$j)(x=>set(get put$j x))") mkString " & "}
    def validate[X](v: Vars, fx: ${mt(TO)} => X): ValidationResult[X] = Invalidity.applicative.apply$a${mt(j => s"${v(j)} validate v._$j")}(fx)
  }
  @inline final def apply[${mc(TTO)}]${mt(vVD)}: V$a[${mc(TTO)}] = V$a${mt(v)}
    """)

  if (false) print(s"""
  final def merge[${mc(TTO)}, X](${mc(vVD)}, fx: ${mt(TO)} => X): FormVar[${mt(T)}, X] = FormVar[${mt(T)}, X](
      ${mt(v(_)+".init")}
      ,G => S => ${m(j => s"${v(j)}.csssel(G._$j)(x=>S(G put$j x))") mkString " & "}
      ,v => Invalidity.applicative.apply$a${mt(j => s"${v(j)} validate v._$j")}(fx)
    )
    """)

  print(s"""
  sealed trait Merge$a[II, ${mc(T)}] { def apply[X](f: ${mt(T)} => X): FormVar[II, X] }
  final def merge[${mc(TTO)}]${mt(vVD)}: Merge$a[${mt(T)}, ${mc(TO)}] = new Merge$a[${mt(T)}, ${mc(TO)}] {
    override def apply[X](fx: ${mt(TO)} => X): FormVar[${mt(T)}, X] = FormVar[${mt(T)}, X](
      (G,S) => ${m(j => s"${v(j)}.csssel(G._$j,x=>S(G put$j x))") mkString " & "}
      ,v => Invalidity.applicative.apply$a${mt(j => s"${v(j)} validate v._$j")}(fx)
    )}
    """)
}
println()
