#!/bin/env scala
// vim: set ft=scala :

def T(i: Int) = (64+i).toChar.toString

for (a <- (2 to 9)) {
  def m (f: Int => String): List[String] = (1 to a).toList.map(f)

  val types = m(t => s"${T(t)}:UnivEq") mkString ", "
  val tuple = m(T).mkString(",")

  println(s"@inline implicit def tuple$a[$types]: UnivEq[($tuple)] = force")

  // var o = List.empty[String]
