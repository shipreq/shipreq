    // def lt(hit: String, miss: Int => String): String = l(hit,miss).mkString("(",comma,")")
//
    // o ::= s"@inline def map$i[X](f: $c => X): (${lc("X",T)}) = ${lt(s"f(_t._$i)", "_t._"+_)}"
    // o ::= s"@inline def put$i[X](x: X): (${lc("X",T)}) = ${lt("x", "_t._"+_)}"
  // }
//
  // println(s"@inline final implicit class Tuple${a}Ext[${mc(T)}](val _t: ${mt(T)}) extends AnyVal {")
  // println(o.sorted.map("  "+_) mkString "\n")
