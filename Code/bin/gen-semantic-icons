#!/bin/bash

set -euo pipefail

cd "$(dirname "$(readlink -e "$0")")/.."

# To camel-case
x='s/^([^!]*)[ _-]([a-z])/$1\u$2/g;'

d=frontend/src/semantic
t=./webapp-base/js/src/main/scala/shipreq/webapp/base/ui/semantic/Icon.scala
tmp=/tmp/icons.scala

[ ! -e $t ] && echo "File not found: $t" && exit 1

used=$(
  cat $d/icons-used \
    | perl -pe 's/\./ /g; s/^ //; s/^(.+)$/"$1"/' \
    | paste -d'|' -s \
    | perl -pe 's/\|/\\\|/g'
  )

icons=$(
  cat $d/icons-all \
    | perl -pe 's/\./ /g; s/^ //; s/^(.+)$/$1! extends Unmodified("$1")/' \
    | perl -pe "$x$x$x$x$x"' s/^(.)/\u$1/; s/^(.+)!/case object $1!/' \
    | column -t -o ' ' -s ! \
    | sed -e "/$used/! s!^!// !" \
    | sed -e "s!^!  !" \
)

sed -n '0,/===== ICONS START =====/p' < $t > $tmp
echo >> $tmp
echo "$icons" >> $tmp
echo >> $tmp
sed -n '/===== ICONS END =====/,$p' < $t >> $tmp

mv $tmp $t
echo "Updated: $t"

echo
git diff -- $t

