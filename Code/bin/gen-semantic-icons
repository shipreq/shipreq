#!/bin/bash
cd "$(dirname "$(readlink -e "$0")")/.." || exit 1

# To camel-case
x='s/^([^!]*)[ _-]([a-z])/$1\u$2/g;'

cat res/semantic/src/themes/default/elements/icon.overrides \
  | grep -e 'i\.icon\.[^ ]*:\(before\|after\)' \
  | perl -pe 's/:.+//; s/i\.icon\.//; s/\./ /g' \
  | sort -u \
  | perl -pe 's/^(.+)$/$1! extends Unmodified("$1")/' \
  | perl -pe "$x$x$x$x$x"' s/^(.)/\u$1/; s/^(.+)!/case object $1!/' \
  | column -t -o ' ' -s !

