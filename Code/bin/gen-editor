#!/bin/env scala
// vim: set ft=scala :

val comma = ", "
def T(i: Int) = (64+i).toChar.toString

for (i <- (1 to 4)) {
  // def m (f: Int â‡’ String): List[String] = (1 to a).toList.map(f)
  // def mc(f: Int â‡’ String): String = m(f).mkString(comma)
  // def mt(f: Int â‡’ String): String = m(f).mkString("(",comma,")")

  // def A(j: Int) = ('A'+j).toChar.toString
  // val As = (0 until i) map A
  // val Ac = As mkString ","
  // val ac = Ac.toLowerCase

  def xn(f: Int â‡’ String): String = (1 to i).map(f).mkString(", ")
  def Xs(x: String) = (1 to i).map(j â‡’ s"$x$j").mkString(",")

  def ABVn = xn(j â‡’ s"A$j,B$j,V$j")
  def As   = Xs("A")
  def Bs   = Xs("B")
  def Vs   = Xs("V")
  def es   = Xs("e")
  def _s   = if (i==1) "identity" else Xs("_._")
  def editorParams  = xn(j â‡’ s"e$j: Editor[A$j,B$j,M,S,Unit,D,V$j]")
  def editorParamsS = xn(j â‡’ s"e$j: Editor[(T,A$j),B$j,M,S,Unit,D,V$j]")
  def iToAn = xn(j â‡’ s"a$j: Iâ‡’A$j")
  def map2n = xn(j â‡’ s"_ map2 a$j")
  def rendn = xn(j â‡’ s"e$j render i$j")

  println(s"""
  def merge$i[M[_], S, D, $ABVn, FS <: FieldSet$i[_,$Bs]](fs: FS, $editorParams) =
    new {
    def tupleI = apply[($As)](${_s})
    def apply[I]($iToAn): Editor[I, fs.FieldValue, M, S, fs.Field, D, ($Vs)] =
      Editor(ei â‡’ {
${(1 to i).map(j => s"        val i$j = ei.mapABC[A$j,B$j,Unit](a$j, fs.f$j * _, _ â‡’ fs.f$j)") mkString "\n"}
        ($rendn)
      })
  }

  def merge${i}S[M[_], T, S, C, D, $ABVn, FS <: FieldSet$i[_,$Bs]](fs: FS, $editorParamsS) =
    new {
      def tupleI = apply[($As)](${_s})
      def apply[I]($iToAn): Editor[(T,I), fs.FieldValue, M, S, fs.Field, D, ($Vs)] =
        merge$i(fs,$es).apply[(T,I)]($map2n)
    }
""")

  // com :+= s"  def composeA[$Ac](y: ($Ac)â‡’X): ($Ac)â‡’Y = y andThenA x"

  // println(s"implicit class Function${i}Ext[$Ac,R](val x: ($Ac) â‡’ R) extends AnyVal {")
  // println(s"  def andThenA[Z](y: Râ‡’Z): ($Ac)â‡’Z = ($ac)â‡’y(x($ac))")
  // println("}")
}
