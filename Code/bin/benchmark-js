#!/bin/bash
cd "$(dirname "$(readlink -e "$0"/..)")" || exit 1

src="$(pwd)/benchmark/js"
cd /tmp/shipreq.sbt/benchmark/js/ || exit 2
rm -rf *.html
ln -s "$src"/*.html .
echo

google-chrome-stable --incognito --user-data-dir=/tmp/chrome-session --enable-benchmarking http://localhost:4000/fast.html &

exec python -m http.server 4000

