#!/bin/bash
cd "$(dirname "$(readlink -e "$0")")"/.. || exit 1

avail_mods="taskman webapp"
[ $# -eq 0 ] && defargs="$avail_mods"

sbt=(
  sbt
  -DMODE=release
  -Dsbt.server.autostart=false
  --mem 8192
)

taskman=0
webapp=0
sbt_test=()
sbt_pkg=()
sbt_push=()

function add_docker {
  module=$1
  image_url_prefix=$2
  image_url_var="${image_url_prefix}_IMAGE_URL"
  sbt_pkg+=($module/docker)
  [ -n "${!image_url_var}" ] && sbt_push+=($module/dockerPush)
}

for m in $defargs "$@"; do
  case "$m" in
    taskman)
      taskman=1
      sbt_test+=(taskman/test)
      add_docker taskman-server TASKMAN
      ;;
    webapp)
      webapp=1
      sbt_test+=(webapp/test)
      add_docker webapp-server WEBAPP
      ;;
    -T|no-test)
      notest=1
      ;;
    -C|no-clean)
      noclean=1
      ;;
    -n|--dry-run)
      dryrun=1
      ;;
    -h|--help)
      echo "Usage: $0 [OPTION]... [MODULE]..."
      echo
      echo "Options:"
      echo "  -C, --no-clean    Don't purge previous output directories"
      echo "  -T, --no-test     Don't run tests"
      echo "  -n, --dry-run     Show the command but don't run it"
      echo
      echo "Modules:"
      echo "  taskman"
      echo "  webapp"
      exit 0
      ;;
    *)
      echo "Unknown module: $m"
      exit 1
  esac
done

case "$((taskman + webapp))" in
  0) exec "$0" $avail_mods "$@" ;;
  1) sbt_test=(base/test "${sbt_test[@]}") ;;
  2) sbt_test=(test) ;;
esac
[ -n "$notest" ] && sbt_test=()
[ -z "$noclean" ] && sbt+=(clean)

# ======================================================================================================================
# Perform release

echo "> ${sbt[@]} ${sbt_test[@]} ${sbt_pkg[@]} ${sbt_push[@]}"
echo
[ -z "$dryrun" ] && time "${sbt[@]}" "${sbt_test[@]}" "${sbt_pkg[@]}" "${sbt_push[@]}"
