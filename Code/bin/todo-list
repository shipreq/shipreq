#!/bin/bash
cd "$(dirname "$(readlink -e "$0")")"/.. || exit 1

[ -z "$colour" ] && colour=always

files=
case "$1" in
  m|main) files=$(find */src/main */*/src/main -type f | fgrep -v .json | fgrep -v base-test/ );;
  t|test) files=$(find */src/test */*/src/test -type f | fgrep -v .json );;
  *)      files=$(find project */src */*/src -type f | fgrep -v .json );;
esac

echo "$files" \
  | egrep -v '/_scalate/|vendor|src/it/|/assets/|/webapp/dev/' \
  | egrep -v 'shipreq-gen-deps\.js$' \
  | fgrep -v 'TypeInfoCache.java' \
  | fgrep -v 'RealProject1.scala' \
  | sort \
  | xargs grep -P --color=$colour -n '(?<!["#])TODO(?!").*' \
  | awk '{match($1,/([a-z_-]+)\/src/,a); if (NR > 1 && a[1] != p[1]) print ""; print} {match($1,/([a-z_-]+)\/src/,p)}' \
  | fgrep -v 'Fix in Scala 3'

