#!/bin/bash

cd /taskman || exit 1

[ $# -lt 1 ] && echo "Usage: $0 <main-class>" && exit 1

main="$1"; shift
cp=conf/:secrets1/:secrets2/:{{cp}}

java_opt=(
  # This will one day be enabled by default
  -XX:+UnlockExperimentalVMOptions
  -XX:+UseCGroupMemoryLimitForHeap

  # Prepare heap on startup rather than incrementally at runtime
  -XX:+AlwaysPreTouch

  # Default in Java 9, may as well use it now
  -XX:+UseG1GC

  # Useful for diagnostics
  -XX:+PrintFlagsFinal
  -XX:+UnlockDiagnosticVMOptions
  -XX:+PrintActiveCpus
  -XshowSettings:vm
)

if [ -z "$client" ]; then
  java_opt+=(-server)
else
  java_opt+=(-client)
fi

java_opt+=(-cp "$cp")

echo "> java $JAVA_OPTS ${java_opt[@]} $main $@"
exec java $JAVA_OPTS "${java_opt[@]}" $main "$@"
