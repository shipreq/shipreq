#!/bin/bash

cd /taskman || exit 1

[ $# -lt 1 ] && echo "Usage: $0 <main-class>" && exit 1

main="$1"; shift
cp=conf/:{{cp}}

java_opt=(
  # Memory usage
  -XX:MaxRAMPercentage=92.0

  # Be specific about the GC we want
  # Also avoid crash: https://github.com/oracle/graal/issues/1892
  -XX:+UseG1GC

  # Use Graal's JIT
  -Dgraal.ShowConfiguration=verbose
  -Dgraal.MitigateSpeculativeExecutionAttacks=None
  -XX:+EagerJVMCI

  # Useful for diagnostics
  -XX:+PrintFlagsFinal
  -XX:+UnlockDiagnosticVMOptions
  -XshowSettings:vm
)

if [ -z "$client" ]; then
  java_opt+=(-server)
else
  java_opt+=(-client)
fi

java_opt+=(-cp "$cp")

echo "> java $JAVA_OPTS ${java_opt[@]} $main $@"
exec java $JAVA_OPTS "${java_opt[@]}" $main "$@"
