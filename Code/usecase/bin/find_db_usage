#!/bin/bash

filter='/(DB|DaoProvider|DI|Defaults)\.'

echo "Session"
find src/main/scala -type f | egrep -v "$filter" | sort | xargs egrep -n --color=auto '(for|with)Session'

echo

echo "Transaction"
find src/main/scala -type f | egrep -v "$filter" | sort | xargs egrep -n --color=auto '(for|with)Transaction'

