#!/bin/bash
cd "$(dirname "$0")" || exit 1

clear
echo /init.sh
echo sbt
echo

exec docker run \
  --rm \
  -it \
  -v"$HOME/.coursier/cache":/to-home/.cache/coursier:ro \
  -v"$(pwd)"/test-local.res/init.sh:/init.sh:ro \
  -v"$(pwd)/../../Code":/Code:ro \
  -w /Code \
  -m 15G \
  -e JAVA_OPTS="-Xms512m -Xmx4g -Xss2m" \
  -e SHIPREQ_RELEASE_TARGET=/shipreq.out \
  shipreq/build \
  bash

  -v"$HOME/.sbt":/to-home/.sbt:ro \
  -v"$HOME/.ivy2":/to-home/.ivy2:ro \
