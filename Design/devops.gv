digraph G {

services [label="ShipReq\nservices" fillcolor=lightblue style=filled]
kamon,logstash [fillcolor=lightblue style=filled]

// Devops cluster
subgraph cluster_devops {
  fillcolor="#e6ffe6"
  style=filled
  node [style=filled fillcolor="#77bb66"]

  es [label="ElasticSearch" fillcolor=lightyellow style=filled]
  jaeger_storage [label="Cassandra" fillcolor=lightyellow style=filled]
  prometheus_storage [label="Cortex |\nInfluxDB |\nTimescaleDB" fillcolor=lightyellow style=filled]
  jaeger [label="[tracing]\njaeger"]
  prometheus [label="[monitoring] [alerting]\nprometheus"]
  grafana [label="[monitoring]\ngrafana"]
  alertmanager [label="[alerting]\nalertmanager"]
  kibana [label="[logging]\nkibana"]

  portal [label="DevOps portal\nCustom, simple HTML"]
  portal -> jaeger,prometheus,grafana,kibana
}

// App
services -> kamon,logstash [arrowhead=none]
portal -> services [constraint=false]
mailchimp,gsuite,freshdesk,mailgun,gcp -> portal [dir=back]

// Monitoring & Alerting
prometheus -> services,kamon,alertmanager
grafana -> prometheus
alertmanager -> email,slack,sms
prometheus -> prometheus_storage [style=dotted]

// Logging
logstash,kibana -> es

// Tracing
kamon -> jaeger
jaeger -> jaeger_storage [style=dotted]

}
