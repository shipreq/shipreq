!!! 5
%html
  %head
    %meta(http-equiv="refresh" content="1")
    %title SHIPREQ PHASE-2 PROTOTYPE
    :css
      body {padding-bottom:12em}
      table {border-collapse: collapse}
      th,td {border: solid 1px #000; padding: 1px 4px}
      .notes {color:#338; margin-top: 2em; margin-left: -3em; font-style:italic}
      .notes ol, .notes ul {margin-top:0.2em}
      section.screen {border-top: solid 1px black; margin-top: 12em; padding-top: 0.7em; padding-left: 4em}
      section.screen > a h1 {margin-top: 0; margin-left: -2.6em}
      span.incmp {color:#c00}
      span.incmp-dull {color:#777}
      .empty {background:#c66}
      .fixpre pre {margin-top:0; margin-bottom:0}
      .na, .na * {color:#777 !important; text-decoration:line-through !important}
      .subscreen {padding-top:1.6em}
      th.l {text-align:left}
      .shrna {text-align:center; color:#888}
      .focuscell {border: solid 2px #008}
      .left-th th {text-align:left}
      .l1 {padding-left:4ex}
      .l2 {padding-left:8ex}
      .del, .del * {opacity:0.5; _color:#666 !important; text-decoration:line-through !important}

      .req-detail .x {border:none; vertical-align:top}
      .req-detail .tt {background:#ddd; text-align:center}
      .causality td {border:none; vertical-align:middle}
      .causality td.a {text-align:right}
      .causality td.b {font-weight:bold}

