!!! 5
%html
  %head
    %title SHIPREQ PHASE-2 PROTOTYPE
    :css
      table {border-collapse: collapse}
      th,td {border: solid 1px #000; padding: 1px 4px}
      .notes {color:#338; margin: 2em; font-style:italic}
      .notes ol, .notes ul {margin-top:0.2em}

  %body
    %h1 SHIPREQ PHASE-2 PROTOTYPE

    %section
      %a#fields
        %h1 Fields


      %h4 Active Fields
      %button Create
      %table
        %tr
          %th Name
          %th RefKey
          %th Field Type
          %th Mandatory
          %th Req Types
          %th Usage
          %th Ctrls
        %tr
          %td Description
          %td \.desc
          %td Text
          %td ☐
          %td Only: MF, UC.
          %td 27
          %td
            %button Edit
            %button Delete
            [Drag]
        %tr
          %td Priority
          %td \.pri
          %td Grouping
          %td ☑
          %td All.
          %td 432
          %td
            %button Edit
            %button Delete
            [Drag]

      %h4 Deleted Fields
      %table
        %tr
          %th Name
          %th RefKey
          %th Field Type
          %th Mandatory
          %th Req Types
          %th Usage
          %th Ctrls
        %tr
          %td Description
          %td \.desc
          %td Text
          %td ☐
          %td Only: MF, UC.
          %td 27
          %td
            %button Restore
            [Drag]


      .notes Notes.
        %ol
          %li Items can be dragged to reorder, or dragged from/to bin.
          %li Some fields will not be editable or deletable.
          %li Usage numbers should be links to references. That would make delete button simple.
          %li Create → Choose req type → Enter common attr {mand, req types} and special attr {grouping, name, ...}
          %li Edit is same form as above.
