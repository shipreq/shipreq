  :javascript
    $('.ui.multiple.dropdown')
      .find('.menu > .item > .ui.dropdown, .menu > .item.ui.dropdown, > .ui.dropdown:not(.simple), .inline.dropdown, .icon.buttons .button, .form .dropdown.selection')
      .dropdown();

    $('.ui.dropdown:not(.onhover)').dropdown();
    $('.ui.dropdown.onhover').dropdown({on:"hover", delay: { show: 400 }});
    $('.ui.has-popup').popup({delay: { show: 400, hide: 0 }});
    $('#cols-button')
      .popup({
        inline   : true,
        hoverable: true,
        position : 'left center',
        delay: {
          show: 200,
          hide: 300
        }
      })
    ;

    $('.ui.modal').modal();
    $('.ui.accordion').accordion('open');

    $('.button').click(function (e) {
      var t = $('#toast')[0];
      if (t.style.visibility == 'hidden') {
        // show
        t.style.visibility = '';
        t.style.opacity = '1';
      } else {
        // hide
        t.style.visibility = 'hidden';
        t.style.opacity = '0';
      }
      e.preventDefault();
      e.stopPropagation();
    });

