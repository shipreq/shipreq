            %tr
              %td ☰
              %td Status
              %td Tag
              %td
                %table.ui.definition.table
                  %tbody
                    %tr
                      %td IV
                      %td Defaults to <div class="ui label yellow is-tag" style="color:#000!important">needs_more_info</div>
                    %tr
                      %td FR, UC
                      %td Defaults to <div class="ui label brown is-tag">needs_analysis</div>
                    %tr
                      %td Other
                      %td Optional
              %td
                <button class="ui button basic  negative " style="white-space: nowrap;"><i class="icon trash"></i>Delete</button>


        -# ==================================================================================================================================================
        %table.ui.celled.table#t2
          %thead
