                  %tbody
                    %tr
                      %td All
                      %td Optional
              %td
            %tr
              %td ☰
              %td Step Graph
              %td Step Graph
              %td
                %table.ui.definition.table
                  %tbody
                    %tr
                      %td UC
                      %td Optional
              %td
            %tr
              %td ☰
              %td Detail
              %td Text
              %td
