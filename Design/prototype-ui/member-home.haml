!!! 5
%html
  %head
    -# %meta(http-equiv="refresh" content="1")
    %title Projects | ShipReq
    %script{src: "node_modules/jquery/dist/jquery.min.js"}
    %link{href:  "../semantic/dist/semantic.min.css", rel: "stylesheet", type: "text/css"}/
    %script{src: "../semantic/dist/semantic.min.js"}
    :css
      body {padding:1rem}

      .ui.header {margin-bottom:0; margin-right:1em}
      .inline-edit1:hover {cursor:pointer; outline:dotted 2px #FFA622; background: #fff4e3 !important}

  %body

    .ui.menu.borderless.fixed.inverted
      .item
        %img{src: "logo-only-dark2.svg"}

      .item
        .ui.breadcrumb
          .section Projects

      .right.menu
        .item
          @japgolly

        .item.ui.dropdown.simple
          @japgolly
          -# %i.dropdown.icon
          .menu
            %a.item{href: "member-member-account.haml.html"} Account
            .item Logout

    .ui.container{style: "margin-top:6rem"}

      %div{style: "margin-bottom:1em"}
        .ui.action.input
          %input{type: "text", placeholder: "New project name..."}
          %button.ui.button.green.disabled{disabled: "disabled"} Create

      %div{style: "margin-bottom:1em"}
        .ui.action.input
          %input{type: "text", placeholder: "New project name...", value: "Phaarrt", disabled: "disabled"}
          %button.ui.button.green.loading{disabled: "disabled"} Create

      %div{style: "margin-bottom:1em"}
        .ui.action.input
          %input{type: "text", placeholder: "New project name...", value: "Phaarrt"}
          %button.ui.button.green Create

      %div{style: "margin-bottom:1em"}
        %div
          .ui.action.input.error
            %input{type: "text", placeholder: "New project name...", value: "Cardboard"}
            %button.ui.button.negative{disabled: "disabled"} Create
        .ui.pointing.red.basic.label
          That name is taken.

      %div{style: "margin-bottom:1em"}
        %div
          .ui.action.input
            %input{type: "text", placeholder: "New project name...", value: "Cardboard"}
            %button.ui.button.primary Create
        .ui.pointing.red.basic.label
          AJAX error.

      .ui.divider{style: "margin:2rem 0"}

      %div{style: "display:flex"}
        %div{style: "flex-grow:1"}
          %h1.ui.header
            %a{href: "project-index.haml.html"}
              CardBoard
          .ui.meta{style: "margin: .5em 0; line-height: 1em; color: rgba(0,0,0,.6);"}
            Updated&nbsp;
            %time{datetime: "2015-12-17T09:24:17Z", title: "December 17, 2015"} 4 months ago.
        %div
          .ui.statistics.tiny
            .statistic
              .value
                %i.icon.write
                &nbsp;209
              .label changes
            .statistic
              .value
                %i.icon.cubes
                &nbsp;39
              .label reqs

      .ui.divider{style: "margin:2rem 0"}

      %div{style: "display:flex"}
        %div{style: "flex-grow:1"}
          %h1.ui.header
            %a{href: "project-index-loading.haml.html"}
              ShipReq
          .ui.meta{style: "margin: .5em 0; line-height: 1em; color: rgba(0,0,0,.6);"}
            Updated&nbsp;
            %time{datetime: "2015-12-17T09:24:17Z", title: "December 17, 2015"} 3 days ago.
        %div
          .ui.statistics.tiny
            .statistic
              .value
                %i.icon.write
                &nbsp;1080
              .label changes
            .statistic
              .value
                %i.icon.cubes
                &nbsp;361
              .label reqs
                -# .statistic
                -#   .value
                -#     %i.icon.database
                -#     &nbsp;1,248.8
                -#   .label KB

  :javascript
    $('.ui.dropdown').dropdown();
