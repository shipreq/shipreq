                %td.members 3 users
                %td.rel %span.admin admin
              %tr
                %td.name.lvl2
                  %i.icon.users
                  Business Team
                %td.members 1 user
                %td.rel %span.admin admin
              %tr
                %td.name.lvl2
                  %i.icon.users
                  Dev Team
                %td.members 3 users
                %td.rel %span.admin admin

