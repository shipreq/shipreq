                      %span.text Add...

            .field
              .ui.segment
                .family
                  %div.h
                    %h4.ui.header Projects
                  %div.b
                    %table
                      %tbody
                        %tr
                          %td
                            %i.icon.archive
                            ShipReq
                          %td
                            .ui.selection.dropdown
                              %i.icon.dropdown
                              .item %span.admin admin
                              .menu
                                .item %span.admin admin
                                .item %span.collab collaborator
                          %td
                            .ui.button.basic.negative.invis(style="white-space: nowrap; float:right; background:#fff!important;") %i.icon.trash(style="margin:0!important")
                        %tr
                          %td
                            %i.icon.folder.open.outline
                            OSS projects
                          %td
                            .ui.selection.dropdown
                              %i.icon.dropdown
                              .item %span.collab collaborator
                              .menu
                                .item %span.admin admin
                                .item %span.collab collaborator
                            %span.inv(style="margin-left:2ex")
                              %i.icon.envelope
                              invitation will be sent
                          %td .ui.button.basic.negative(style="white-space: nowrap; float:right; background:#fff!important;") %i.icon.trash(style="margin:0!important")
                        %tr
                          %td
                            %i.icon.archive
                            Whatever
                          %td
                            .ui.selection.dropdown
                              %i.icon.dropdown
                              .item %span.collab collaborator
                              .menu
                                .item %span.admin admin
                                .item %span.collab collaborator
                          %td .ui.button.basic.negative(style="white-space: nowrap; float:right; background:#fff!important;") %i.icon.trash(style="margin:0!important")
                  %div.f
                    .ui.floating.labeled.icon.dropdown.button
                      %i.icon.plus
                      %span.text Add...

            -# .field
              .ui.segment
                .family
                  %div.h
                    %h4.ui.header
                      Invitation pages
                      %span(style="opacity:.3; margin-left")
                  %div.b
                    %table
                      %tbody
                        %tr
                          %td
                            %i.icon.archive
                            ShipReq
                          %td %span.admin admin
                          %td
                            .ui.button.basic.negative.invis(style="white-space: nowrap; float:right; background:#fff!important;") %i.icon.trash(style="margin:0!important")
                        %tr
                          %td
                            %i.icon.folder.open
                            OSS projects
                          %td.inv
                            %i.icon.envelope
                            collaborator access requested
                          %td .ui.button.basic.negative(style="white-space: nowrap; float:right; background:#fff!important;") %i.icon.trash(style="margin:0!important")
                        %tr
                          %td
                            %i.icon.archive
                            Whatever
                          %td %span.collab collaborator
                          %td .ui.button.basic.negative(style="white-space: nowrap; float:right; background:#fff!important;") %i.icon.trash(style="margin:0!important")
                  %div.f
                    .ui.floating.labeled.icon.dropdown.button
                      %i.icon.plus
                      %span.text Create for collaborators...
                    .ui.floating.labeled.icon.dropdown.button(style="margin-left:2ex")
                      %i.icon.plus
                      %span.text Create for admin...

            %div(style="text-align:right; margin-top:2rem")
              %button.ui.button.black.basic(style="margin-right:2em")
                %i.icon.remove
                Close
              %button.ui.button.green(style="margin-right:0!important")
                %i.icon.plus
                Create

