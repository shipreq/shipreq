%html
  %head
    -# %meta(http-equiv="refresh" content="1")
    %title CardBoard Req Table | ShipReq
    %script{src: "../node_modules/jquery/dist/jquery.min.js"}
    %link{href:  "../semantic/dist/semantic.min.css", rel: "stylesheet", type: "text/css"}/
    %script{src: "../semantic/dist/semantic.js"}
    :css
      body {padding:1rem}
      .ui.menu.inverted .ui.breadcrumb a {color: #63c0ff}
      .ui.menu.inverted .ui.breadcrumb a:hover {color: #9bf3ff}
      .ui.menu.inverted .ui.breadcrumb > i {color: #ddd; margin-left: 0.8em; margin-right: 0.8em;}

      .ui.button.basic {background:#fff!important}

      .is-tag {
        padding: 4px 6px !important;
        margin-left: .5ex !important;
      }

      main {
        xbackground:#fbb;
        margin-top: 4rem;
        min-height: calc(100vh - 2 * (0.928571em + 1rem) - 2.5em);
        min-height: calc(100vh - 2.79rem - 3rem);
        min-height: calc(100vh - 6rem);
        display:grid;
        grid-template-columns: 1fr 2rem 2rem 1fr;
      }

      section.gap2 {
        border-left: solid 1px #e8e8e8;
      }

      .tagtree {
        margin:0;
        padding-left:0;
      }
      #tagtree {
        margin-top:2.5rem;
      }
      .tagtree ol {
        padding-left:6.5ex;
      }
      .tagtree li {
        list-style-type: none;
      }
      .tagtree .drag {
        display: inline;
        padding:.5em 1ex 0.5em 2ex;
        margin-left: -2ex;
        cursor:grab;
      }
      #tagtree > li.group:not(:first-child), #tagtree > li.tag.first_after_group {
        border-top: solid 1px #2224261a;
      }
      #tagtree > li:not(:first-child) {
        margin-top: 1.25em;
      }
      #tagtree li.tag:not(:last-child) {
        border-bottom:solid 1px blue;
        border-bottom: solid 1px #2224261a;
      }
      .tagtree li.tag {
        padding-top: .5em;
        padding-bottom: .5em;
      }
      .tagtree .group i {
        margin-right:0.4ex!important;
      }
      #tagtree .group > div {
        font-size: 120%;
        padding:0.4em 0;
      }
      #tagtree li.group > div, #tagtree li.tag {
        cursor:pointer;
      }
      #tagtree:not(.has-selection) li.group > div:hover,
      #tagtree:not(.has-selection) li.tag:hover {
        background-color: #fffad7 !important;
      }
      #tagtree .selected {
        background-color: #869df91f;
        border-top:solid 1px #3659e2;
        border-bottom:solid 1px #3659e2!important;
      }
      #tagtree.has-selection .tag:not(.selected),
      #tagtree.has-selection .group > div:not(.selected) {
        opacity:.4;
        transition: all .4s;
      }
      .tagtree li {
        clear: both;
      }

      .right-off {
        overflow: hidden; height: 0; opacity: 0;
        transition: height 0s .4s, opacity .4s 0s;
      }
      .right-on {
        height: auto; opacity: 1;
        transition: height 0s 0s, opacity .4s 0s;
      }

      #family {
        display:flex;
        margin-top:1rem;
      }
      #family > * {
        width:50%;
      }
      #family > * > * {
        height:100%;
      }
      #family > .parents {
        padding-right:0.5rem;
      }
      #family > .children {
        xborder-left: solid 1px #e8e8e8;
        padding-left:0.5rem;
      }
      .family {
        display:flex;
        flex-direction:column;
        height:100%;
      }
      .family > .h {
        margin-bottom:1em;
      }
      .family > .b {
        flex-grow:1;
      }
      .family .tagtree {
        margin-left:2ex;
        margin-top:0.25em;
        margin-bottom:2em;
      }
      .family .tagtree li.tag {
        margin-left:2ex;
        margin-bottom:1em;
      }
      .family .tagtree .button {
        margin:-0.5em 0 .5em 0!important;
      }
      .family .lvl1 {padding-left:3ex}
      .family .lvl2 {padding-left:6ex}
      .family .ui.dropdown .menu>.item {
        padding-top   :0.4em!important;
        padding-bottom:0.4em!important;
      }

      .no-error,
      .no-error .text {
        color:#0009!important;
        background:#e8e8e8!important;
        border-color:#0000!important;
      }

  -# ==================================================================================================================================================
  -# ==================================================================================================================================================
  %body

    .ui.menu.borderless.fixed.inverted
      .item
        %img{src: "logo-only-dark2.svg"}

      .item
        .ui.breadcrumb
          %a.section{href: "member-home.html"} Projects
          %i.divider.icon.right.angle
          %a.section{href: "project-index.html"} CardBoard
          .ui.dropdown.inline
            &nbsp;
            %i.icon.dropdown
            .menu
              .item.active CardBoard
              .item ShipReq
          %i.divider.icon.right.angle
          .section // .active
            .ui.dropdown.inline
              Req Table
              &nbsp;
              %i.icon.dropdown
              .menu
                .header Content
                .item Implication Graph
                .item.active ReqTable
                .header Configuration
                .item Fields
                .item Issues
                .item Req Types
                .item Tags

      .item.ui.right.dropdown.simple
        @japgolly
        -# %i.dropdown.icon
        .menu
          %a.item{href: "member-account.html"} Account
          .item Logout

    %main

      %section.left

        %div(style="display:flex; margin-bottom:2rem")
          %div
            .ui.labeled.button.disabled#new
              %a.ui.button.green
                %i.icon.plus
                New
              -# .ui.floating.dropdown.labeled.search.button.label
              .ui.dropdown.label{style: "background-color: #00a632; color: #EEE;"}
                Tag group
                %i.icon.dropdown
                .menu
                  .item Tag
                  .item Tag group

          %div(style="flex-grow:1")

          %div(style="")
            %button.ui.button.icon
              %i.icon.trash.outline.large.grey


        -# ==================================================================================================================================================
        %ol#tagtree.has-selection.tagtree

          %li.group
            %div
              %i.icon.folder.open.outline
              Actors

          %li.group
            %div
              %i.icon.folder.open.outline
              Status
            %ol
              %li.tag
                .drag ☰
                .ui.label.is-tag.yellow(style="margin:0;color:#000!important") needs_more_info
              %li.tag
                .drag ☰
                .ui.label.is-tag.brown(style="margin:0") needs_analysis
              %li.tag
                .drag ☰
                .ui.label.is-tag.blue(style="margin:0") analysed
              %li.tag
                .drag ☰
                .ui.label.is-tag.pink(style="margin:0") ready_for_dev
              %li.tag
                .drag ☰
                .ui.label.is-tag.olive(style="margin:0; color:#000!important") implemented

          %li.group
            %div
              %i.icon.folder.open.outline
              Priority
            %ol
              %li.tag
                .drag ☰
                .ui.label.is-tag.red(style="margin:0") must
              %li.tag.selected#should
                .drag ☰
                .ui.label.is-tag.orange(style="margin:0; xcolor:#000!important") should
              %li.tag
                .drag ☰
                .ui.label.is-tag.yellow(style="margin:0; color:#000!important") could

          %li.group
            %div
              %i.icon.folder.open.outline
              Version

            %ol
              %li.group
                %div
                  %i.icon.folder.open.outline
                  Released

            %ol
              %li.group
                %div
                  %i.icon.folder.open.outline
                  In Testing

            %ol
              %li.group
                %div
                  %i.icon.folder.open.outline
                  Unreleased
                %ol
                  %li.tag
                    .drag ☰
                    .ui.label.is-tag.blue(style="margin:0") v1.0
                  %li.tag
                    .drag ☰
                    .ui.label.is-tag.blue(style="margin:0") v1.1

                %li.tag
                  .drag ☰
                  .ui.label.is-tag.blue(style="margin:0") tbd

      -# ==================================================================================================================================================
      %section.gap1
      %section.gap2

      %section.right

        .right-off#noeditor(style="display:flex; flex-direction: column; font-size:120%")
          %div(style="height:calc((100vh - 6rem)/4); xbackground:red")
          %div(style="text-align:center; font-style:italic; color:#999; line-height: 1.8em")
            %div This is the tag editor.
            %div Create a new tag, or select an existing tag to edit it here.

        .right-on#editor
          %h2(style="color: #3659e2; margin-bottom:2rem")
            -# %pre(style="margin:0") should
            .ui.label.is-tag.orange(style="margin:0!important; font-size:100%") should
            -# should

          .ui.form
            .field
              %label Name
              %input(type="text" value="should")
            .field
              %label Colour
              -# %input(type="text" value="#f2711c" style="width:16ex")
              -# %div(style="margin-left:2ex; display:inline")
                Choose:
                .ui.buttons
                  %button.ui.button simple
                  %button.ui.button full
              %div(style="width:20ex")
                .ui.action.input
                  %input(type="text" value="#f2711c")
                  %button.ui.button Simple colours
                  %button.ui.button All colours
            .field
              %label Description
              %textarea(rows="2" value="wtf" placeholder="")
            .field.error
              %label Applicable Req Types
              .ui.labeled.input
                .ui.dropdown.label.no-error
                  .text Blacklist
                  %i.icon.dropdown
                  .menu
                    .item Blacklist
                    .item Whitelist
                %input(type="text" value="XA" placeholder="Req types..." style="border-left-width:0")
              %div(style="margin-top:0.15em")
                %div(style="float:right; color:#444")
                  Dead req types:
                  %span(style="margin-left:1ex; xtext-decoration:line-through; color:#999") MF, FR
                <span style="color: rgb(159, 58, 56); padding-top: 0.15rem; font-size: 92%;">XA isn't a valid req type you fucken idiot</span>
          #family
            .parents
              .ui.segment
                .family
                  %div.h
                    %h4.ui.header Parents
                  %div.b
                    %ol.tagtree
                      %li.group
                        %div
                          %i.icon.folder.open.outline
                          Priority
                          .ui.button.basic.negative(style="white-space: nowrap; float:right") %i.icon.trash(style="margin:0!important")
                  %div.f
                    .ui.floating.labeled.icon.dropdown.button
                      %i.icon.plus
                      %span.text Add parent...

          %div(style="margin-top:2rem; display:flex")
            %button.ui.button.negative.basic(style="white-space: nowrap;")
              %i.icon.trash
              Delete
            %div(style="flex-grow:1")
            %button.ui.button.black.basic(style="margin-right:2em")
              %i.icon.remove
              Close
            -# %button.ui.button.basic.green(style="border-color: #080 !important; font-weight: bold !important;")
            %button.ui.button.green.disabled
              %i.icon.plus
              Update

  :javascript
    $('.ui.dropdown').dropdown();
    $('.outline').toggleClass('outline');

    $('#tagtree').click(function() {
      $('#tagtree').toggleClass('has-selection');
      $('#should').toggleClass('selected');
      $('#noeditor,#editor').toggleClass('right-on');
      $('#noeditor,#editor').toggleClass('right-off');
      $('#new').toggleClass('disabled');
    });
