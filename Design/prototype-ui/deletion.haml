      -# %section
        %textarea.texteditor This has been replaced by [uc19]
        .instructions
          %span enter for new line.
          %i.icon.help.circle
        .ui.segments.preview-cont.raised
          .ui.segment.preview-header.inverted
            Preview
          .ui.segment.preview-body
            = "This has been replaced by "
            %a{href:"#"} UC-19

