!!! 5
%html
  %head
    -# %meta(http-equiv="refresh" content="1")
    %title CardBoard | ShipReq
    %script{src: "../node_modules/jquery/dist/jquery.min.js"}
    %link{href:  "../semantic/dist/semantic.min.css", rel: "stylesheet", type: "text/css"}/
    %script{src: "../semantic/dist/semantic.min.js"}
    :css
      body {padding:1rem}
      .ui.menu.inverted .ui.breadcrumb a {color: #63c0ff}
      .ui.menu.inverted .ui.breadcrumb a:hover {color: #9bf3ff}
      .ui.menu.inverted .ui.breadcrumb > i {color: #ddd; margin-left: 0.8em; margin-right: 0.8em;}

      .texteditor {
        width:100%;
        margin: 0;
        -webkit-appearance: none;
        tap-highlight-color: rgba(255,255,255,0);
        padding: .78571429em 1em;
        outline: 0;
        color: rgba(0,0,0,.87);
        border-radius: .28571429rem;
        box-shadow: 0 0 0 0 rgba(0, 0, 0, 0) inset;
        -webkit-transition: color .1s ease,border-color .1s ease;
        transition: color .1s ease,border-color .1s ease;
        font-size: 1em;
        line-height: 1.2857;
        /*overflow: scroll;*/
        resize: none;
        padding:.3em .4em !important;
        background: #fffad7 !important;
        border:solid 1px rgba(239,207,9,0.6) !important;
      }
      .instructions {
        font-size: 0.75rem;
        line-height: 1em;
        color: #a4a6a8;
        text-align: right;
        margin-bottom: 0.4em;
      }
      .instructions i {
        margin-left: 0.4ex !important;
        margin-right: 0 !important;
        cursor: pointer;
      }
      .preview-cont {margin:0 !important}
      .preview-header {padding-top: 0.3em !important; padding-bottom: 0.3em !important; background:#89d6e5!important; color:#0d1516!important}
      .preview-body {
        background-clip: border-box !important;
        background-color: rgba(0, 0, 0, 0)  !important;
        background-image: repeating-linear-gradient(-225deg,
          rgba(0, 0, 0, 0),
          rgba(0, 0, 0, 0)        5ex,
          rgba(137,214,229, 0.1)  5ex,
          rgba(137,214,229, 0.1) 10ex) !important;
        background-origin: padding-box  !important;
      }

      #main > table {margin-bottom:4em}

      #table1 >thead>tr>th,
      #table1 >tbody>tr>td {padding:.44em!important}
      #table1 >tbody>tr>td {line-height: 1em}
      #table1 .col-sel {width:24px; text-align:center}
      #table1 .pointer {cursor:pointer}
      #table1 td.col-title {display:flex}
      #table1 td.col-title .indent-1 {width: 1.5ex}
      #table1 td.col-title .indent-2 {width: 4.5ex}
      #table1 td.col-title .prefix::before {content:"↳"}
      #table1 td.col-title .title {flex-grow:1; padding-left:1ex}
      #table1 .imp {white-space:nowrap}
      #table1 .imp:not(:first-child) {margin-left:1ex}
      #table1 .imp:not(:last-child)::after {content:","}
      #table1 .imp.dead {color:red}
      #table1 .imp.live {}
      #table1 tr.live:hover {background-color:rgba(0,0,0,.08)}
      #table1 tr.dead {background-color:rgba(255,0,0,.05)}
      #table1 tr.dead:hover {background-color:rgba(255,0,0,.13)}
      #table1 tr.dead .col-title {color:red}

      #table2 >thead>tr>th,
      #table2 >tbody>tr>td {padding:.44em!important}
      #table2 >tbody>tr>td {line-height: 1em}
      #table2 .col-sel {width:24px; text-align:center}
      #table2 .pointer {cursor:pointer}
      #table2 td.col-id {display:flex; white-space:nowrap}
      #table2 td.col-id .indent-1 {width: 0ex}
      #table2 td.col-id .indent-2 {width: 2ex}
      #table2 td.col-id .prefix {color:#a8a8a8}
      #table2 td.col-id .prefix::before {content:"↳"}
      #table2 td.col-id .id:not(:first-child) {flex-grow:1; padding-left:0.5ex}
      #table2 .imp {white-space:nowrap}
      #table2 .imp:not(:first-child) {margin-left:1ex}
      #table2 .imp:not(:last-child)::after {content:","}
      #table2 tr.live:hover {background-color:rgba(0,192,0,.08)}
      #table2 tr.dead {background-color:hsla(0, 71%, 50%, .06)}
      #table2 tr.dead:hover {background-color:hsla(0, 71%, 50%, .15)}
      #table2 .imp.dead,
      #table2 tr.dead .col-id .id,
      #table2 tr.dead .col-title {color:hsl(0, 71%, 50%)}

      #table3 {margin-top:1ex}
      #table3 >thead>tr>th:last-child {text-align:center}
      #table3 >thead>tr:nth-child(2)>th {text-align:center; padding-top:0!important}
      #table3 >thead i.icon {margin:0!important}
      #table3 >thead>tr>th,
      #table3 >tbody>tr>td {padding:.44em!important}
      #table3 >tbody>tr>td {line-height: 1em}
      /*#table3 >tbody>tr>td:last-child {border-left:none!important}*/
      #table3 .col-sel {width:24px; text-align:center}
      #table3 .pointer {cursor:pointer}
      #table3 td.col-id {display:flex; white-space:nowrap}
      #table3 td.col-id .indent-1 {width: 0ex}
      #table3 td.col-id .indent-2 {width: 2ex}
      #table3 td.col-id .prefix {color:#a8a8a8}
      #table3 td.col-id .prefix::before {content:"↳"}
      #table3 td.col-id .id:not(:first-child) {flex-grow:1; padding-left:0.5ex}
      #table3 .imps span {white-space:nowrap}
      #table3 .imps span:not(:first-child) {margin-left:1ex}
      #table3 .imps span:not(:last-child)::after {content:","}
      #table3 tr.live:hover {background-color:rgba(0,192,0,.08)}
      #table3 tr.dead {background-color:hsla(0, 71%, 50%, .06)}
      #table3 tr.dead:hover {background-color:hsla(0, 71%, 50%, .15)}
      #table3 .col-imp.dead span,
      #table3 tr.dead .col-id .id,
      #table3 tr.dead .col-title {color:hsl(0, 71%, 50%)}

      #table-cg-1 {margin-top:1ex}
      #table-cg-1 >thead>tr>th:last-child {text-align:center}
      #table-cg-1 >thead>tr:nth-child(2)>th {text-align:center; padding-top:0!important}
      #table-cg-1 >thead i.icon {margin:0!important}
      #table-cg-1 >thead>tr>th,
      #table-cg-1 >tbody>tr>td {padding:.44em!important}
      #table-cg-1 >tbody>tr>td {line-height: 1em}
      #table-cg-1 .col-sel {width:24px; text-align:center}
      #table-cg-1 .pointer {cursor:pointer}
      #table-cg-1 td.col-code {white-space:nowrap; font-family:monospace; font-size:85%}
      #table-cg-1 .subs span {white-space:nowrap}
      #table-cg-1 .subs span:not(:first-child) {margin-left:1ex}
      #table-cg-1 .subs span:not(:last-child)::after {content:","}
      #table-cg-1 tr.live:hover {background-color:rgba(0,192,0,.08)}
      #table-cg-1 tr.dead {background-color:hsla(0, 71%, 50%, .06)}
      #table-cg-1 tr.dead:hover {background-color:hsla(0, 71%, 50%, .15)}
      #table-cg-1 .col-sub.dead span,
      #table-cg-1 tr.dead .col-id .id,
      #table-cg-1 tr.dead .col-title {color:hsl(0, 71%, 50%)}

  %body

    %nav(style="margin-bottom:5rem")
      .ui.menu.borderless.fixed.inverted
        .item
          %img{src: "logo-only-dark2.svg"}

        .item
          .ui.breadcrumb
            %a.section{href: "member-home.haml.html"} Projects
            %i.divider.icon.right.angle
            .ui.dropdown.inline
              CardBoard&nbsp;
              %i.icon.dropdown
              .menu
                .item.active CardBoard
                .item ShipReq

        .item.ui.right.dropdown.simple
          @japgolly
          -# %i.dropdown.icon
          .menu
            %a.item{href: "member-account.haml.html"} Account
            .item Logout

    -# =============================================================================================
    .ui.container#main

