resources:
- name: {{ properties['DB_INSTANCE'] }}
  type: sqladmin.v1beta4.instance
  properties:
    region: {{ properties['GCP_REGION'] }}
    databaseVersion: POSTGRES_9_6
    settings:
      tier: db-f1-micro
      dataDiskSizeGb: 10
      activationPolicy: ALWAYS
      locationPreference:
        zone: {{ properties['GCP_ZONE'] }}
      backupConfiguration:
        enabled: true
        startTime: "16:00"
      maintenanceWindow:
        day: 6
        hour: 16
- name: db-shipreq
  type: sqladmin.v1beta4.database
  properties:
    instance: $(ref.{{ properties['DB_INSTANCE'] }}.name)
    name: shipreq
