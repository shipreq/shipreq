#!/bin/bash

set -uo pipefail

# cd "$(dirname "$0")" || exit 1
[ $# -eq 0 ] && echo "Usage: $0 [args] <module>" && exit 1

cmd=(unbuffer tlc-colour)

while [ $# -gt 1 ]; do
  cmd+=("$1")
  shift
done
module="$1"

tmp=/tmp/$(date +%Y%m%d-%H%M%S)-$$
mkdir $tmp
# trap "rm -rf $tmp" EXIT

./convert_dialect <$module.tla >$tmp/$module.tla
./convert_dialect <Util.tla >$tmp/Util.tla
cp $module.cfg $tmp
cmd+=($module)

echo "> cd $tmp && ${cmd[@]}"
cd $tmp

"${cmd[@]}"
r=$?

if [ $r -eq 0 ]; then
  rm -rf $tmp
fi

exit $r