@startuml

[*] --> cfgG
[*] --> applyG

state "[CONFIGURE GROUPINGS]\nSee groupings as tree\nSee grouping allocation graph" as cfgG
cfgG : add
cfgG : delete
cfgG : move
cfgG : modify
cfgG : restore
cfgG : see how groupings have been allocated

cfgG : bulk apply
cfgG --> applyG

state "[APPLY GROUPINGS]\nSee list of UCs\nSee filters\nSee grouping allocation graph" as applyG
applyG : change filter
applyG : see how groupings have been allocated
applyG : apply grouping(s)
applyG : unapply grouping(s)
applyG : edit groupings
applyG -> cfgG

cfgG --> graphInspect : click graph segment
applyG --> graphInspect : click graph segment

state "See grouping name & number of UCs" as graphInspect
graphInspect : modify groupings of matching UCs
graphInspect : see which UCs have the given grouping
graphInspect --> applyG : Use criteria as filter in [APPLY GROUPINGS]

state "Grouping Editor" as editG
cfgG -> editG : add | modify
editG : cancel
editG : apply changes
editG : modify name
editG : modify desc
editG : modify parents
editG : modify children
editG -> cfgG

[*] --> browseG
state "[BROWSE GROUPINGS]\nSee each grouping at current level\nSee application details per grouping\nSee count of UCs with top-level unapplied" as browseG
browseG : ???

@enduml

' state "Accumulate Enough Data\nLong State Name" as long1

